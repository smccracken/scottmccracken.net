---
import { getCollection } from 'astro:content';
import Container from '@/components/Container.astro';
import Timeline, { type TimelineItem } from '@/components/Timeline.astro';
import TitleBlock from '@/components/TitleBlock.astro';
import PageLayout from '@/layouts/PageLayout.astro';

const entries = await getCollection('now');

entries.sort((a, b) => b.id.localeCompare(a.id));

function formatEntryDate(id: string): string {
  const [year, month] = id.replace(/\.[^.]+$/, '').split('-');
  const date = new Date(`${year}-${month}-01T00:00:00Z`);
  return date.toLocaleDateString('en-US', {
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

const nowItems: TimelineItem[] = entries.map((entry) => ({
  date: formatEntryDate(entry.id),
  description: entry.body?.trim() ?? '',
}));
---

<PageLayout title="Now" description="What Scott McCracken is up to right now.">
  <Container class="flow">
    <TitleBlock>
      <h1><span class="eyebrow">What I'm up to</span> Now</h1>
    </TitleBlock>

    <section class="flow">
      <Timeline items={nowItems} />
    </section>
  </Container>
</PageLayout>
