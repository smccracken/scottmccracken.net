---
import Container from '@/components/Container.astro';
import Timeline, { type TimelineItem } from '@/components/Timeline.astro';
import TitleBlock from '@/components/TitleBlock.astro';
import PageLayout from '@/layouts/PageLayout.astro';

const timelineItems: TimelineItem[] = [
  {
    title: 'Software Engineer at Accessible Web',
    titleUrl: 'https://accessibleweb.com',
    date: 'July 2021 – Present',
    description:
      'Building tools and monitoring services to help others fix accessibility violations with their websites and applications.',
  },
  {
    title: 'Director of Web Development at CarComplaints.com',
    titleUrl: 'https://www.carcomplaints.com',
    date: 'May 2010 – July 2021',
    description:
      'Managed content and expanded audience reach for a large network of car related sites aimed at turning car problems into solutions.',
  },
  {
    title: 'Web Development Instructor with Vermont HITEC',
    titleUrl: 'https://www.accessibleweb.com',
    date: 'February 2007 – April 2007',
    description:
      'Developed a course to teach Vermont residents with no prior web development experience how to build flexible and customizable templates, from start to finish.',
  },
  {
    title: 'Senior Front End Developer at Dealer.com',
    titleUrl: 'https://www.dealer.com',
    date: 'September 2003 – May 2010',
    description:
      'Focused on building highly performant and customizable templates for car dealership websites. I pushed forward an initiative to make our templates more accessible and SEO friendly.',
  },
];
---

<PageLayout title="About Scott McCracken" description="Front-end developer living in Vermont.">
  <Container class="flow">
    <TitleBlock>
      <h1><span class="eyebrow">About</span> Scott McCracken</h1>
      <h2>Front-end developer from Vermont.</h2>
    </TitleBlock>

    <section class="flow">
      <p>Building for the web has been my thing ever since I scrabbled together my first GeoCities site over a spotty dial-up connection. I've been hooked ever since and have managed to turn that into a 23-year career.</p>

      <p>Over that time I’ve been happiest in the front of the front-end, where small details can have <em>big</em> impacts on how an interface feels to use. No matter my role <mark>I always advocate for the user</mark>.</p>

      <p>That said, I’ve also worked across the full stack long enough to know that great front-end work doesn't happen in isolation. Servers, databases, APIs — it all shapes the end product.</p>

      <Timeline items={timelineItems} />

      <h2>Outside of Work</h2>
      <p>Off the clock, life in northern Vermont keeps things grounded. There's a garden to tend, two rescue mutts to walk, and — thanks to a mostly vegetarian household — a genuinely excellent pot of beans to perfect. When I'm not staring at a screen, I'm usually skiing, hiking, or taking photographs. Someday I'll get around to woodworking.</p>
    </section>

  </Container>
</PageLayout>
