{
  "name": "scottmccracken.net",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check": "astro check && biome check",
    "check:fix": "biome check --write",
    "dev": "astro dev",
    "html-validate": "pnpm build && pnpm exec html-validate dist/*.html",
    "prepare": "husky",
    "preview": "astro preview",
    "style-lint": "stylelint \"src/**/*.{css,astro}\"",
    "style-lint:fix": "stylelint \"src/**/*.{css,astro}\" --fix"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/ts-plugin": "^1.10.7",
    "astro": "^6.0.8",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "rollup": "^4.59.0",
      "lodash": "^4.17.23",
      "svgo": "^4.0.1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "cssnano": "^7.1.3",
    "html-validate": "^10.11.2",
    "husky": "^9.1.7",
    "stylelint": "^17.5.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0"
  }
